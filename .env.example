# Copy to .env and adjust. The platform runs fully offline with NO settings.
# Provider: offline (default) | openai | anthropic
IKI_AI_PROVIDER=offline
# Used only when provider is openai/anthropic:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# IKI_GENERATION_MODEL=gpt-4o-mini
# Retrieval tuning (optional)
IKI_TOP_K=6
IKI_CHUNK_SIZE=900
IKI_DATA_DIR=iki_store
